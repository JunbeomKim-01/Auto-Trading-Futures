{
  "name": "auto-trading-futures",
  "version": "0.1.0",
  "private": true,
  "description": "Binance Futures auto-trading strategy platform on Cloudflare Workers (MVP)",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply trading_db --local",
    "db:migrate": "wrangler d1 migrations apply trading_db --remote",
    "db:seed:local": "wrangler d1 execute trading_db --local --file=./db/seed.sql",
    "db:seed": "wrangler d1 execute trading_db --remote --file=./db/seed.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.0.0"
  }
}
